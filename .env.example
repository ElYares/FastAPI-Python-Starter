# App
APP_NAME=FastAPI Starter
APP_ENV=development
DEBUG=true
LOG_LEVEL=info
LOG_FORMAT=auto

# CORS (CSV)
ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:5173
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type,Accept,Origin
CORS_ALLOW_CREDENTIALS=true

# Security headers
SECURITY_HEADERS_ENABLED=true
HSTS_MAX_AGE_SECONDS=31536000

# JWT
JWT_SECRET_KEY=CHANGE_ME_USE_A_LONG_RANDOM_VALUE
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_MINUTES=10080

# Login rate limiting
LOGIN_RATE_LIMIT_ATTEMPTS_PER_IP=20
LOGIN_RATE_LIMIT_ATTEMPTS_PER_USER=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60

UID=1000
GID=1000

DATABASE_URL=sqlite:///./app.db
DB_ECHO=false
